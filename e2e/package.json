{
  "name": "saucedemo-e2e",
  "version": "1.0.0",
  "description": "E2E test automation for SauceDemo using Cypress + TypeScript",
  "private": true,
  "scripts": {
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:chrome": "cypress run --browser chrome",
    "cy:run:headless": "cypress run --headless --browser chrome",
    "cy:run:headed": "cypress run --headed --browser chrome",
    "test": "cypress run",
    "report:open": "start reports/e2e-test-report.html",
    "clean": "if exist reports rmdir /s /q reports && if exist screenshots rmdir /s /q screenshots && if exist videos rmdir /s /q videos"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "cypress": "^13.15.0",
    "cypress-mochawesome-reporter": "^3.8.0",
    "typescript": "^5.6.0"
  }
}
